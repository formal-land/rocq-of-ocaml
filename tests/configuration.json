{
  "alias_barrier_modules": ["AliasBarrier"],
  "constructor_map": [["int", "OldConstructor", "NewConstructor"]],
  "constant_warning": false,
  "error_category_blacklist": ["not_supported"],
  "error_filename_blacklist": ["tests/ignored.ml"],
  "error_message_blacklist": ["ignored message"],
  "escape_value": ["escaped_value"],
  "first_class_module_path_blacklist": ["Blocked.Module"],
  "first_class_module_signature_blacklist": ["Blocked.Signature"],
  "head_suffix": "(* ConfigurationSuffix *)",
  "merge_returns": [["M.return", "N.return", "Merged.return"]],
  "merge_types": [["M.t", "N.t", "Merged.t"]],
  "monadic_lets": [["let_star", "let*"]],
  "monadic_let_returns": [["let_star_return", "bind", "return"]],
  "monadic_returns": [["return", "return"]],
  "monadic_return_lets": [["return_let", "bind", "return"]],
  "operator_infix": [["plus", "+"]],
  "renaming_rules": [["Old.path", "New.path"]],
  "renaming_type_constructor": [["old_type", "new_type"]],
  "require": [["OldRequire", "NewRequire"]],
  "require_import": [["OldRequireImport", "NewRequireImport"]],
  "require_long_ident": [["OldLongIdent", "NewLongIdent"]],
  "require_mli": ["Configuration"],
  "variant_constructors": [["A", "VariantA"]],
  "variant_types": [["A", "variant_type"]],
  "without_guard_checking": ["tests/configuration.ml"],
  "without_positivity_checking": ["tests/configuration.ml"]
}
